#include <stdlib.h>
#include <struct.h>

/**
 * @brief Simple test that checks whether the random number generator has
 *        has been initialized
 */
START_TEST(test_init) { 
  struct liste T;
  init_liste_char(&T);
  ck_assert_int_eq(T.nbmots, 0);
}
END_TEST

START_TEST(test_array) {
  struct liste T;
  char mot[100] = "Bonjour\0";
  init_liste_char(&T);
  ajout_liste(&T, mot);
  ck_assert_int_eq(T.nbmots, 1);
}
END_TEST

START_TEST(test_2mots_egaux) {
  struct liste T;
  char mot[100] = "Bonjour\0";
  init_liste_char(&T);
  ajout_liste(&T, mot);
  ajout_liste(&T, mot);
  ck_assert_int_eq(T.nbmots, 1);
}
END_TEST

START_TEST(test_ponctuation) {
  struct liste T;
  char mot[100] = "bonjour.\0";
  char motverif[100] = "bonjour\0";
  init_liste_char(&T);
  ajout_liste(&T, mot);
  ck_assert_str_eq(T.tete->mot, motverif);
}
END_TEST

START_TEST(test_tri_freq) {
  struct liste T;
  char motdiff[100] = "hello\0";
  char mot[100] = "bonjour\0";
  char mot2[100] = "bonjour\0";
  init_liste_char(&T);
  ajout_liste(&T, motdiff);
  ajout_liste(&T, mot);
  ajout_liste(&T, mot2);
  char *tab[T.nbmots];
  int freq[T.nbmots];
  tri_occ(&T, tab, freq);
  ck_assert_int_eq(freq[0], 2);
}
END_TEST


START_TEST(test_tri_mot) {
  struct liste T;
  char motdiff[100] = "hello\0";
  char mot[100] = "bonjour\0";
  char mot2[100] = "bonjour\0";
  init_liste_char(&T);
  ajout_liste(&T, motdiff);
  ajout_liste(&T, mot);
  ajout_liste(&T, mot2);
  char *tab[T.nbmots];
  int freq[T.nbmots];
  tri_occ(&T, tab, freq);
  ck_assert_str_eq(tab[0], mot );
}
END_TEST

START_TEST(test_majuscule) {
  struct liste T;
  char mot[100] = "Bonjour.\0";
  char mot2[100] = "bonjour\0";
  init_liste_char(&T);
  ajout_liste(&T, mot);
  ajout_liste(&T, mot2);
  ck_assert_int_eq(T.nbmots, 1);
}
END_TEST


START_TEST(test_tri_ordre_alpha) {
  struct liste T;
  char mot1[100] = "hello\0";
  char mot2[100] = "bonjour\0";
  init_liste_char(&T);
  ajout_liste(&T, mot1);
  ajout_liste(&T, mot2);
  char *tab[T.nbmots];
  int freq[T.nbmots];
  tri_occ(&T, tab, freq);
  ck_assert_str_eq(tab[0], mot2 );
}
END_TEST


Suite *sort_suite(void) {
  Suite *s = suite_create("SortText");
  TCase *tc_core = tcase_create("Core");
  tcase_add_test(tc_core, test_init);
  tcase_add_test(tc_core, test_array);
  tcase_add_test(tc_core, test_2mots_egaux);
  tcase_add_test(tc_core, test_ponctuation);
  tcase_add_test(tc_core, test_majuscule);
  tcase_add_test(tc_core, test_tri_freq);
  tcase_add_test(tc_core, test_tri_mot);
  tcase_add_test(tc_core, test_tri_ordre_alpha);
  suite_add_tcase(s, tc_core);

  return s;
}



int main(void) {
  int no_failed = 0;
  Suite *s = sort_suite();
  SRunner *runner = srunner_create(s);
  srunner_run_all(runner, CK_NORMAL);
  no_failed = srunner_ntests_failed(runner);
  srunner_free(runner);
  return (no_failed == 0) ? EXIT_SUCCESS : EXIT_FAILURE;
}
